ALL_KEYS = sorted(ALL_MAP.keys(), key=len, reverse=True)


def transpile_csp(code):
    result = []
    i = 0
    length = len(code)

    while i < length:
        char = code[i]

        if char in ('"', "'"):
            quote = char
            string_literal = quote
            i += 1

            while i < length:
                char = code[i]
                string_literal += char

                if char == '\\' and i + 1 < length:
                    i += 1
                    string_literal += code[i]
                elif char == quote:
                    i += 1
                    break

                i += 1

            result.append(string_literal)
            continue

        if char == '#':
            comment = ''
            while i < length and code[i] != '\n':
                comment += code[i]
                i += 1
            result.append(comment)
            continue

        if char == 'f' and i + 1 < length and code[i+1] in ('"', "'"):
            quote = code[i+1]
            string_literal = 'f' + quote
            i += 2

            while i < length:
                char = code[i]
                string_literal += char

                if char == '\\' and i + 1 < length:
                    i += 1
                    string_literal += code[i]
                elif char == quote:
                    i += 1
                    break
                elif char == '{' and i + 1 < length and code[i+1] != '{':
                    brace_count = 1
                    i += 1
                    expr = ''
                    while i < length and brace_count > 0:
                        char = code[i]
                        if char == '{':
                            brace_count += 1
                        elif char == '}':
                            brace_count -= 1
                            if brace_count == 0:
                                break
                        expr += char
                        i += 1

                    transpiled_expr = transpile_csp(expr)
                    string_literal += transpiled_expr + '}'
                    i += 1
                    continue

                i += 1

            result.append(string_literal)
            continue

        matched = False
        for key in ALL_KEYS:
            if code.startswith(key, i):
                before_ok = i == 0 or not (code[i-1].isalnum() or code[i-1] == '_')
                after_pos = i + len(key)
                after_ok = after_pos >= length or not (code[after_pos].isalnum() or code[after_pos] == '_')

                if before_ok and after_ok:
                    result.append(ALL_MAP[key])
                    i += len(key)
                    matched = True
                    break

        if not matched:
            result.append(char)
            i += 1

    return ''.join(result)


