def run_csp(code, filename='<цсп>'):
    python_code = transpile_csp(code)
    csp_lines = code.splitlines()

    print("=" * 60)
    print("🕯 ИСХОДНЫЙ КОД (ЦСП):")
    print("=" * 60)
    print(code)
    print()
    print("=" * 60)
    print("🐍 ТРАНСПИЛИРОВАННЫЙ КОД (Python):")
    print("=" * 60)
    print(python_code)
    print()
    print("=" * 60)
    print("⚡ РЕЗУЛЬТАТ ВЫПОЛНЕНИЯ:")
    print("=" * 60)

    # Сначала компилируем — ловим SyntaxError до запуска
    try:
        скомпилировано = compile(python_code, filename, 'exec')
    except SyntaxError as e:
        _возгласить_ошибку(e, csp_lines)
        return python_code

    # Запускаем
    try:
        exec(скомпилировано, {'__name__': '__main__'})
    except KeyboardInterrupt:
        print()
        print("  ☩ Служба прервана. Мир твоей душе. ☩")
        print()
    except Exception as e:
        _возгласить_ошибку(e, csp_lines)

    return python_code


