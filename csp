def _перевести_сообщение(exc):
    """Переводит стандартное Python-сообщение на церковнославянский лад."""
    тип = type(exc).__name__
    msg = str(exc)

    if тип == 'NameError':
        m = re.search(r"name '(.+?)' is not defined", msg)
        if m:
            return f"имя '{m.group(1)}' не обретено в свитке имён"
        m = re.search(r"free variable '(.+?)' referenced before assignment", msg)
        if m:
            return f"свободная переменная '{m.group(1)}' призвана прежде присвоения"

    elif тип in ('SyntaxError', 'IndentationError', 'TabError'):
        return f"{exc.msg} (строка {exc.lineno})"

    elif тип == 'TypeError':
        if 'unsupported operand type' in msg:
            m = re.search(r"unsupported operand type\(s\) for (.+?): '(.+?)' and '(.+?)'", msg)
            if m:
                return f"действие '{m.group(1)}' невозможно меж '{m.group(2)}' и '{m.group(3)}'"
        if 'can only concatenate' in msg:
            m = re.search(r"can only concatenate (\w+) \(not \"(.+?)\"\) to (\w+)", msg)
            if m:
                return f"нельзя соединить '{m.group(1)}' с '{m.group(2)}' — природы несовместимы"
        if 'takes' in msg and 'argument' in msg:
            m = re.search(r"(\w+\(\)) takes (\d+) positional argument", msg)
            if m:
                return f"сотворение '{m.group(1)}' требует {m.group(2)} подношений — не более и не менее"
        if "'NoneType' object is not" in msg:
            return "пытаешься использовать ничтоже (None) как нечто — тщетно"
        if 'not callable' in msg:
            m = re.search(r"'(.+?)' object is not callable", msg)
            if m:
                return f"'{m.group(1)}' не есть функция — призывать его нельзя"

    elif тип == 'ZeroDivisionError':
        return "деление на ничтоже — сие богопротивно"

    elif тип == 'IndexError':
        m = re.search(r"list index out of range", msg)
        if m:
            return "место в списке выходит за пределы его длины"
        return msg

    elif тип == 'KeyError':
        return f"ключ {msg} не обретён в словнике"

    elif тип == 'AttributeError':
        m = re.search(r"'(.+?)' object has no attribute '(.+?)'", msg)
        if m:
            return f"сущность '{m.group(1)}' не имать свойства '{m.group(2)}'"

    elif тип == 'FileNotFoundError':
        m = re.search(r"\[Errno \d+\] .+?: '(.+?)'", msg)
        if m:
            return f"свиток '{m.group(1)}' не обретён на пути мирском"

    elif тип == 'RecursionError':
        return "дух заблудился в бесконечном круге — рекурсия без конца и края"

    elif тип in ('ImportError', 'ModuleNotFoundError'):
        m = re.search(r"No module named '(.+?)'", msg)
        if m:
            return f"модуль '{m.group(1)}' не обретён нигде во вселенной"

    elif тип == 'ValueError':
        if 'invalid literal for int' in msg:
            m = re.search(r"invalid literal for int\(\) with base \d+: '(.+?)'", msg)
            if m:
                return f"'{m.group(1)}' не есть число — нечестивый ввод"
        if 'could not convert string to float' in msg:
            m = re.search(r"could not convert string to float: '(.+?)'", msg)
            if m:
                return f"'{m.group(1)}' не есть дробь — нечестивый ввод"

    return msg  # если не опознали — оставляем как есть


def _возгласить_ошибку(exc, csp_lines=None):
    """Выводит ошибку в церковнославянском стиле."""
    import traceback

    тип = type(exc).__name__
    осуждение, объяснение = КНИГА_ГРЕХОВ.get(тип, ('ПРЕГРЕШЕНИЕ', 'Неведомая ошибка постигла программу'))
    перевод = _перевести_сообщение(exc)

    print()
    print("☩" * 30)
    print(f"  ☠  {осуждение}  ☠")
    print("☩" * 30)
    print(f"  Природа греха : {объяснение}")
    print(f"  Подробности   : {перевод}")

    # Для синтаксических ошибок — линия из SyntaxError
    if isinstance(exc, SyntaxError):
        if exc.lineno:
            print(f"  Строка греха  : {exc.lineno}")
        if exc.text:
            print(f"  Грешный текст : {exc.text.strip()}")
            if exc.offset:
                указатель = ' ' * (exc.offset - 1) + '☝'
                print(f"                  {указатель}")
        if csp_lines and exc.lineno and exc.lineno <= len(csp_lines):
            оригинал = csp_lines[exc.lineno - 1].strip()
            if оригинал:
                print(f"  В оригинале   : {оригинал}")
    else:
        # Для рантайм-ошибок — берём последний фрейм трейсбека
        tb = traceback.extract_tb(exc.__traceback__)
        if tb:
            последний = tb[-1]
            print(f"  Строка греха  : {последний.lineno}")
            if последний.line:
                print(f"  Грешный текст : {последний.line.strip()}")
            # Показываем оригинальную CSP-строку (номера совпадают 1:1)
            if csp_lines and последний.lineno <= len(csp_lines):
                оригинал = csp_lines[последний.lineno - 1].strip()
                if оригинал and оригинал != последний.line.strip():
                    print(f"  В оригинале   : {оригинал}")

    print("☩" * 30)
    print("  Да покается грешник и исправит деяния свои.")
    print("☩" * 30)
    print()


